sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/viz/ui5/controls/VizFrame",                                                                                                                                                                                                                           
    "sap/viz/ui5/data/FlattenedDataset",                                                                                                                                                                                                                       
	"sap/viz/ui5/data/DimensionDefinition",                                                                                                                                                                                                                       
	"sap/viz/ui5/data/MeasureDefinition",                                                                                                                                                                                                                         
	"sap/viz/ui5/controls/common/feeds/FeedItem",                                                                                                                                                                                                                 
    "sap/suite/ui/commons/ChartContainerContent"                                                                                                                                                                                                               
],                                                                                                                                                                                                                                                             
    /**                                                                                                                                                                                                                                                        
     * @param {typeof sap.ui.core.mvc.Controller} Controller                                                                                                                                                                                                   
     */                                                                                                                                                                                                                                                        
    function (Controller, VizFrame, FlattenedDataset, DimensionDefinition, MeasureDefinition, FeedItem, ChartContainerContent) {                                                                                                                               
        "use strict";                                                                                                                                                                                                                                          
        var aFilters={                                                                                                                                                                                                                                         
            "Appname": [],                                                                                                                                                                                                                                     
            "Userid": []                                                                                                                                                                                                                                       
        };                                                                                                                                                                                                                                                     
        return Controller.extend("com.mindset.voe.FeedbackDetail.controller.App", {                                                                                                                                                                            
            onInit: function () {                                                                                                                                                                                                                              
                var oVizFrameApp = this.getView().byId("idVizFrameApp");                                                                                                                                                                                       
                oVizFrameApp.addFeed(new FeedItem({                                                                                                                                                                                                            
                    uid: "valueAxis",                                                                                                                                                                                                                          
                    type: "Measure",                                                                                                                                                                                                                           
                    values: ['Rating']                                                                                                                                                                                                                         
                }));                                                                                                                                                                                                                                           
                oVizFrameApp.addFeed(new FeedItem({                                                                                                                                                                                                            
                    uid: "categoryAxis",                                                                                                                                                                                                                       
                    type: "Dimension",                                                                                                                                                                                                                         
                    values: ['Appname']                                                                                                                                                                                                                        
                }));                                                                                                                                                                                                                                           
                oVizFrameApp.setDataset(new FlattenedDataset({                                                                                                                                                                                                 
                    dimensions: [new DimensionDefinition({                                                                                                                                                                                                     
                        name: 'Appname',                                                                                                                                                                                                                       
                        value: "{Appname}"                                                                                                                                                                                                                     
                    })],                                                                                                                                                                                                                                       
                    measures: [new MeasureDefinition({                                                                                                                                                                                                         
                        name: 'Rating',                                                                                                                                                                                                                        
                        value: "{Rating}"                                                                                                                                                                                                                      
                    })],                                                                                                                                                                                                                                       
                    data: {                                                                                                                                                                                                                                    
                        path: "/FeedbackGraphSet"                                                                                                                                                                                                              
                    }                                                                                                                                                                                                                                          
                }));                                                                                                                                                                                                                                           
                oVizFrameApp.setVizProperties({                                                                                                                                                                                                                
                    categoryAxis: {                                                                                                                                                                                                                            
                        title: {                                                                                                                                                                                                                               
                            visible: false                                                                                                                                                                                                                     
                        }                                                                                                                                                                                                                                      
                    },                                                                                                                                                                                                                                         
                    plotArea: {                                                                                                                                                                                                                                
                        dataPointStyle: {                                                                                                                                                                                                                      
                            "rules": [{                                                                                                                                                                                                                        
                                "dataContext": {                                                                                                                                                                                                               
                                    "Rating": 5                                                                                                                                                                                                                
                                },                                                                                                                                                                                                                             
                                "properties": {                                                                                                                                                                                                                
                                    "color": "sapUiChartPaletteSemanticGood"                                                                                                                                                                                   
                                },                                                                                                                                                                                                                             
                                "displayName": "Great"                                                                                                                                                                                                         
                            }, {                                                                                                                                                                                                                               
                                "dataContext": {                                                                                                                                                                                                               
                                    "Rating": 4                                                                                                                                                                                                                
                                },                                                                                                                                                                                                                             
                                "properties": {                                                                                                                                                                                                                
                                    "color": "sapUiChartPaletteSemanticGoodLight2"                                                                                                                                                                             
                                },                                                                                                                                                                                                                             
                                "displayName": "Good"                                                                                                                                                                                                          
                            }, {                                                                                                                                                                                                                               
                                "dataContext": {                                                                                                                                                                                                               
                                    "Rating": 3                                                                                                                                                                                                                
                                },                                                                                                                                                                                                                             
                                "properties": {                                                                                                                                                                                                                
                                    "color": "sapUiChartPaletteSemanticCriticalLight1"                                                                                                                                                                         
                                },                                                                                                                                                                                                                             
                                "displayName": "Neutral"                                                                                                                                                                                                       
                            }, {                                                                                                                                                                                                                               
                                "dataContext": {                                                                                                                                                                                                               
                                    "Rating": 2                                                                                                                                                                                                                
                                },                                                                                                                                                                                                                             
                                "properties": {                                                                                                                                                                                                                
                                    "color": "sapUiChartPaletteSemanticBadLight2"                                                                                                                                                                              
                                },                                                                                                                                                                                                                             
                                "displayName": "Needs Work"                                                                                                                                                                                                    
                            }, {                                                                                                                                                                                                                               
                                "dataContext": {                                                                                                                                                                                                               
                                    "Rating": 1                                                                                                                                                                                                                
                                },                                                                                                                                                                                                                             
                                "properties": {                                                                                                                                                                                                                
                                    "color": "sapUiChartPaletteSemanticBad"                                                                                                                                                                                    
                                },                                                                                                                                                                                                                             
                                "displayName": "Bad"                                                                                                                                                                                                           
                            },]                                                                                                                                                                                                                                
                        }                                                                                                                                                                                                                                      
                    },                                                                                                                                                                                                                                         
                    valueAxis: {                                                                                                                                                                                                                               
                        title: {                                                                                                                                                                                                                               
                            visible: false                                                                                                                                                                                                                     
                        },                                                                                                                                                                                                                                     
                        label: {}                                                                                                                                                                                                                              
                    },                                                                                                                                                                                                                                         
                    title: {                                                                                                                                                                                                                                   
                        visible: false                                                                                                                                                                                                                         
                    },                                                                                                                                                                                                                                         
                    legend: {                                                                                                                                                                                                                                  
                        visible: false                                                                                                                                                                                                                         
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
               oVizFrameApp.attachSelectData(this.filterTable, this);                                                                                                                                                                                          
               oVizFrameApp.attachDeselectData(this.filterTable, this);                                                                                                                                                                                        
            },                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            filterTable: function (oEvent) {                                                                                                                                                                                                                   
                var oTable = this.getView().byId("fullTable1");                                                                                                                                                                                                
                var sChartSelection = this.getView().byId('idChartSelect').getSelectedKey();                                                                                                                                                                   
                var oSelData = oEvent.getParameter("data")[0]["data"];                                                                                                                                                                                         
                var sSelType = oEvent.getParameter('name');                                                                                                                                                                                                    
                var sProp, oFilters=[];                                                                                                                                                                                                                        
                if(sChartSelection == '0'){                                                                                                                                                                                                                    
                    sProp = "Appname";                                                                                                                                                                                                                         
                } else {                                                                                                                                                                                                                                       
                    sProp = "Userid";                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
                if(sSelType === 'selectData'){                                                                                                                                                                                                                 
                    aFilters[sProp].push(oSelData[sProp]);                                                                                                                                                                                                     
                } else {                                                                                                                                                                                                                                       
                    aFilters[sProp].splice(aFilters[sProp].findIndex(function(el){                                                                                                                                                                             
                        return el === oSelData[sProp];                                                                                                                                                                                                         
                    }), 1);                                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
                for(var i=0; i<aFilters[sProp].length; i++){                                                                                                                                                                                                   
                    oFilters.push(new sap.ui.model.Filter(sProp, sap.ui.model.FilterOperator.Contains, aFilters[sProp][i]))                                                                                                                                    
                }                                                                                                                                                                                                                                              
                var aFilter = new sap.ui.model.Filter({                                                                                                                                                                                                        
                    filters: oFilters,                                                                                                                                                                                                                         
                    and: false                                                                                                                                                                                                                                 
                });                                                                                                                                                                                                                                            
                oTable.getBinding("rows").filter(aFilter, "Application");                                                                                                                                                                                      
            },                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            onTableRefrehPress: function () {                                                                                                                                                                                                                  
                var oTable = this.getView().byId("fullTable1");                                                                                                                                                                                                
                var nFilter = new sap.ui.model.Filter([new sap.ui.model.Filter("Appname", sap.ui.model.FilterOperator.Contains, "")], false);                                                                                                                  
                oTable.getBinding("rows").filter(nFilter, "Application");                                                                                                                                                                                      
            },                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            toolbarChange: function (oEvent) {                                                                                                                                                                                                                 
                var btn = this.getView().byId("refreshIcon");                                                                                                                                                                                                  
                var bool = oEvent.getParameter("selectedItemId").includes("fullTable1");                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                if (bool) {                                                                                                                                                                                                                                    
                    btn.setVisible(true);                                                                                                                                                                                                                      
                } else {                                                                                                                                                                                                                                       
                    btn.setVisible(false);                                                                                                                                                                                                                     
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            },                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            handleChartDropDown: function (oEvent) {                                                                                                                                                                                                           
                var oChartContainer = this.getView().byId("chartContainer");                                                                                                                                                                                   
                var oTable = this.getView().byId("fullTable1");                                                                                                                                                                                                
                var oVizFrameApp = this.getView().byId("idVizFrameApp");                                                                                                                                                                                       
                var aDimension, sPath;                                                                                                                                                                                                                         
                //clear the values which stored for filtering the table data                                                                                                                                                                                   
                aFilters={                                                                                                                                                                                                                                     
                    "Appname": [],                                                                                                                                                                                                                             
                    "Userid": []                                                                                                                                                                                                                               
                };                                                                                                                                                                                                                                             
                oVizFrameApp.removeAllFeeds();                                                                                                                                                                                                                 
                oTable.getBinding("rows").filter([], "Application");                                                                                                                                                                                           
                oVizFrameApp.addFeed(new FeedItem({                                                                                                                                                                                                            
                    uid: "valueAxis",                                                                                                                                                                                                                          
                    type: "Measure",                                                                                                                                                                                                                           
                    values: ['Rating']                                                                                                                                                                                                                         
                }));                                                                                                                                                                                                                                           
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                var key = oEvent.getParameter("selectedItem");                                                                                                                                                                                                 
                if (key.getKey() === "0") {                                                                                                                                                                                                                    
                    sPath = "/FeedbackGraphSet";                                                                                                                                                                                                               
                    aDimension = [new DimensionDefinition({                                                                                                                                                                                                    
                        name: 'Appname',                                                                                                                                                                                                                       
                        value: "{Appname}"                                                                                                                                                                                                                     
                    })];                                                                                                                                                                                                                                       
                    oVizFrameApp.addFeed(new FeedItem({                                                                                                                                                                                                        
                        uid: "categoryAxis",                                                                                                                                                                                                                   
                        type: "Dimension",                                                                                                                                                                                                                     
                        values: ['Appname']                                                                                                                                                                                                                    
                    }));                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                } else if (key.getKey() === "1") {                                                                                                                                                                                                             
                    sPath = "/FeedbackGraph1Set";                                                                                                                                                                                                              
                    aDimension = [new DimensionDefinition({                                                                                                                                                                                                    
                        name: 'Userid',                                                                                                                                                                                                                        
                        value: "{Userid}"                                                                                                                                                                                                                      
                    })];                                                                                                                                                                                                                                       
                    oVizFrameApp.addFeed(new FeedItem({                                                                                                                                                                                                        
                        uid: "categoryAxis",                                                                                                                                                                                                                   
                        type: "Dimension",                                                                                                                                                                                                                     
                        values: ['Userid']                                                                                                                                                                                                                     
                    }));                                                                                                                                                                                                                                       
                }                                                                                                                                                                                                                                              
                oVizFrameApp.setDataset(new FlattenedDataset({                                                                                                                                                                                                 
                    dimensions: aDimension,                                                                                                                                                                                                                    
                    measures: [new MeasureDefinition({                                                                                                                                                                                                         
                        name: 'Rating',                                                                                                                                                                                                                        
                        value: "{Rating}"                                                                                                                                                                                                                      
                    })],                                                                                                                                                                                                                                       
                    data: {                                                                                                                                                                                                                                    
                        path: sPath                                                                                                                                                                                                                            
                    }                                                                                                                                                                                                                                          
                }));                                                                                                                                                                                                                                           
                oChartContainer.updateChartContainer();                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            },                                                                                                                                                                                                                                                 
            formatDate: function (sValue) {                                                                                                                                                                                                                    
                const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];                                                                                                                                           
                var oDate = new Date(sValue);                                                                                                                                                                                                                  
                var sNewDate = months[oDate.getMonth()] + " " + oDate.getDate() + " " + oDate.getFullYear() + " " + oDate.getHours() + ":" + oDate.getMinutes() + ":" + oDate.getSeconds();                                                                    
                return sNewDate;                                                                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
    });                                                                                                                                                                                                                                                        