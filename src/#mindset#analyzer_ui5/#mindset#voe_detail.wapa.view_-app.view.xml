<mvc:View                                                                                                                                                                                                                                                      
    controllerName="com.mindset.voe.FeedbackDetail.controller.App"                                                                                                                                                                                             
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    displayBlock="true"                                                                                                                                                                                                                                        
    xmlns:viz="sap.viz.ui5.controls"                                                                                                                                                                                                                           
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"                                                                                                                                                                                                        
    xmlns:viz.data="sap.viz.ui5.data"                                                                                                                                                                                                                          
    xmlns:chart="sap.suite.ui.commons"                                                                                                                                                                                                                         
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:table="sap.ui.table"                                                                                                                                                                                                                                 
>                                                                                                                                                                                                                                                              
    <Shell id="shell">                                                                                                                                                                                                                                         
        <App id="app">                                                                                                                                                                                                                                         
            <pages>                                                                                                                                                                                                                                            
                <Page id="page" title="{i18n>title}" showHeader="false" showFooter="false" enableScrolling="false">                                                                                                                                            
                    <content>                                                                                                                                                                                                                                  
                        <chart:ChartContainer class="sapUiTinyMargin" id="chartContainer" autoAdjustHeight="true" showFullScreen="true" showZoom="false" enableScroll="true" contentChange="toolbarChange" title="Feedback Analysis">                          
                            <chart:dimensionSelectors>                                                                                                                                                                                                         
                                <Select id="idChartSelect" change="handleChartDropDown">                                                                                                                                                                       
                                    <core:Item key="0" text="Average Rating by App" />                                                                                                                                                                         
                                    <core:Item key="1" text="Average Rating by User" />                                                                                                                                                                        
                                </Select>                                                                                                                                                                                                                      
                            </chart:dimensionSelectors>                                                                                                                                                                                                        
                            <chart:ChartContainerContent id="AppContent" icon="sap-icon://vertical-bar-chart" title="{Average Rating}">                                                                                                                        
                                <chart:content>                                                                                                                                                                                                                
                                        <viz:VizFrame id="idVizFrameApp" uiConfig="{applicationSet:'fiori'}" height='80%' width="100%" vizType="bar" vizProperties="{plotArea: { drawingEffect: 'glossy'}}">                                                   
                                    </viz:VizFrame>                                                                                                                                                                                                            
                                </chart:content>                                                                                                                                                                                                               
                            </chart:ChartContainerContent>                                                                                                                                                                                                     
                            <chart:ChartContainerContent id="tableChart1" icon="sap-icon://table-chart" title="{Feedback Table}">                                                                                                                              
                                <chart:content>                                                                                                                                                                                                                
                                    <table:Table id="fullTable1" rows="{path: '/FeedbackSet', sorter: { path: 'LogTime', descending: true}}" visibleRowCount="20" editable="false" selectionMode="None">                                                       
                                        <table:columns>                                                                                                                                                                                                        
                                            <table:Column width="11rem" sortProperty="Appname" filterProperty="Appname">                                                                                                                                       
                                                <Label text="App Name" />                                                                                                                                                                                      
                                                <table:template>                                                                                                                                                                                               
                                                    <Text text="{Appname}" wrapping="false" />                                                                                                                                                                 
                                                </table:template>                                                                                                                                                                                              
                                            </table:Column>                                                                                                                                                                                                    
                                            <table:Column width="11rem" hAlign="Center">                                                                                                                                                                       
                                                <Label text="Rating" />                                                                                                                                                                                        
                                                <table:template>                                                                                                                                                                                               
                                                    <Text text="{Rating}" wrapping="false" />                                                                                                                                                                  
                                                </table:template>                                                                                                                                                                                              
                                            </table:Column>                                                                                                                                                                                                    
                                            <table:Column width="25rem" hAlign="Center">                                                                                                                                                                       
                                                <Label text="Comments" />                                                                                                                                                                                      
                                                <table:template>                                                                                                                                                                                               
                                                    <Text text="{Comments}" wrapping="true" />                                                                                                                                                                 
                                                </table:template>                                                                                                                                                                                              
                                            </table:Column>                                                                                                                                                                                                    
                                            <table:Column width="16rem" hAlign="Center" sortProperty="Userid" filterProperty="Userid">                                                                                                                         
                                                <Label text="User Name" />                                                                                                                                                                                     
                                                <table:template>                                                                                                                                                                                               
                                                    <Text text="{Userid}" wrapping="true" />                                                                                                                                                                   
                                                </table:template>                                                                                                                                                                                              
                                            </table:Column>                                                                                                                                                                                                    
                                            <table:Column width="20rem" hAlign="Center" sortProperty="LogTime" filterProperty="LogTime">                                                                                                                       
                                                <Label text="Log Time" />                                                                                                                                                                                      
                                                <table:template>                                                                                                                                                                                               
                                                    <Text text="{path: 'LogTime', type: 'sap.ui.model.type.DateTime', formatOptions: {style: 'medium', UTC:false}}" wrapping="true" />                                                                         
                                                </table:template>                                                                                                                                                                                              
                                            </table:Column>                                                                                                                                                                                                    
                                        </table:columns>                                                                                                                                                                                                       
                                    </table:Table>                                                                                                                                                                                                             
                                </chart:content>                                                                                                                                                                                                               
                            </chart:ChartContainerContent>                                                                                                                                                                                                     
                            <chart:customIcons>                                                                                                                                                                                                                
                                <core:Icon id="refreshIcon" visible="false" src="sap-icon://refresh" tooltip="Refresh Table" press="onTableRefrehPress" />                                                                                                     
                            </chart:customIcons>                                                                                                                                                                                                               
                        </chart:ChartContainer>                                                                                                                                                                                                                
                    </content>                                                                                                                                                                                                                                 
                </Page>                                                                                                                                                                                                                                        
            </pages>                                                                                                                                                                                                                                           
        </App>                                                                                                                                                                                                                                                 
    </Shell>                                                                                                                                                                                                                                                   
</mvc:View>                                                                                                                                                                                                                                                    