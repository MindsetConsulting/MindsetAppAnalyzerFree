sap.ui.define([                                                                                                                                                                                                                                                
	"sap/ui/vbm/AnalyticMap",                                                                                                                                                                                                                                     
	"sap/ui/model/json/JSONModel",                                                                                                                                                                                                                                
	"sap/ui/model/odata/v2/ODataModel",                                                                                                                                                                                                                           
	"sap/base/Log"                                                                                                                                                                                                                                                
], function (AnalyticMap, JSONModel, ODataModel, Log) {                                                                                                                                                                                                        
	"use strict";                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
	var SERVICE_URL = "/sap/opu/odata/MINDSET/FIORI_MONITOR_SRV/";                                                                                                                                                                                                
	AnalyticMap.GeoJSONURL = sap.ui.require.toUrl("com/mindset/appanalyzer/media/analyticmap/L0.json");                                                                                                                                                           
                                                                                                                                                                                                                                                               
	return {                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
		onInit: function () {                                                                                                                                                                                                                                        
			var oView = this.getView();                                                                                                                                                                                                                                 
			this.byId("vbi").setCenterPosition("-111.8976165;40.7689351;0");                                                                                                                                                                                            
			this.byId("vbi").setLegendVisible(false);                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
			var oGeoModel = new JSONModel({                                                                                                                                                                                                                             
				"GeoLocations": []                                                                                                                                                                                                                                         
			});                                                                                                                                                                                                                                                         
			oView.setModel(oGeoModel, "GeoModel");                                                                                                                                                                                                                      
			this.getGeoPos();                                                                                                                                                                                                                                           
		},                                                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
		getGeoPos: function () {                                                                                                                                                                                                                                     
			var that = this;                                                                                                                                                                                                                                            
			var oGeoModel = that.getView().getModel("GeoModel");                                                                                                                                                                                                        
			var oDataModel = new ODataModel(SERVICE_URL, { useBatch: false });                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
			oDataModel.read("/GeoLogInSet", {                                                                                                                                                                                                                           
				success: function (oData) {                                                                                                                                                                                                                                
					if (oData.results.length > 0) {                                                                                                                                                                                                                           
						for (var i = 0; i < oData.results.length; i++) {                                                                                                                                                                                                         
							oData.results[i]["tooltip"] = "Location " + i;                                                                                                                                                                                                          
						}                                                                                                                                                                                                                                                        
						oGeoModel.setProperty("/GeoLocations", oData.results);                                                                                                                                                                                                   
						that.byId("vbi").setCenterPosition(oData.results[0].pos);                                                                                                                                                                                                
					}                                                                                                                                                                                                                                                         
				},                                                                                                                                                                                                                                                         
				error: function (oError) {                                                                                                                                                                                                                                 
					Log.error("Failed to load GeoLogInSet", oError);                                                                                                                                                                                                          
				}                                                                                                                                                                                                                                                          
			});                                                                                                                                                                                                                                                         
		},                                                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
		onAfterRendering: function () {                                                                                                                                                                                                                              
			this.byId("vbi").setCenterPosition("-111.8976165;40.7689351;0");                                                                                                                                                                                            
		}                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
	};                                                                                                                                                                                                                                                            
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               