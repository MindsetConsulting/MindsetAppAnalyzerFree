{
  "_version": "1.28.0",
  "sap.app": {
    "id": "com.mindset.flpext",
    "type": "component",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.8.3",
      "toolsId": "3f040b6f-2ab2-44bb-9a12-f9232eb90095"
    },
    "dataSources": {
      "Monitoring": {
        "uri": "/sap/opu/odata/mindset/FIORI_MONITOR_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/Monitoring/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "com-mindset-flpext-inbound": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "hideLauncher": true,
          "semanticObject": "Shell",
          "action": "plugin",
          "title": "{{flpTitle}}",
          "subTitle": "{{flpSubtitle}}",
          "icon": ""
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.84.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.suite.ui.generic.template": {},
        "sap.ui.comp": {},
        "sap.ui.generic.app": {},
        "sap.ui.table": {},
        "sap.ushell": {}
      }
    },
    "componentName": "com.mindset.flpext",
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.mindset.flpext.i18n.i18n"
        }
      },
      "Monitoring": {
        "dataSource": "Monitoring",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    }
  },
  "sap.flp": {
    "type": "plugin",
    "config": {}
  },
  "sap.cloud": {
    "public": true,
    "service": "com-mindset-flpext"
  }
}
