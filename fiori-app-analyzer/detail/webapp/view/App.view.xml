<mvc:View controllerName="com.mindset.appanalyzerdetail.controller.App"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m" xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
	xmlns:smartTable="sap.ui.comp.smarttable">
    <Shell id="shell">
		<App id="app">
			<pages>
				<Page id="page" title="{i18n>appTitle}" showHeader="false" titleAlignment="Center">
					<content>
						<VBox id="idVBox" fitContainer="true">
							<smartTable:SmartTable 
								id="LineItemsSmartTable" 
								entitySet="DetailSet" 
								tableType="ResponsiveTable"
								useVariantManagement="false" 
								header="User Details"
								demandPopin="true"
								beforeRebindTable="onBeforeRebindTable"
								enableAutoBinding="true" 
								initiallyVisibleFields="UserId,AppDescription,Browser,DeviceType,LogTime"
								class="sapUiResponsiveContentPadding">
								<!-- layout data used to make the table growing but the filter bar fixed -->
								<smartTable:layoutData>
									<FlexItemData id="idFlexItemData" growFactor="1" baseSize="0%"/>
								</smartTable:layoutData>
							</smartTable:SmartTable>
						</VBox>
					</content>
				</Page>
			</pages>
		</App>
	</Shell>
</mvc:View>
